---
import { portfolioData } from '../data/portfolio.js';

const data = portfolioData.personal;
---

<section id="about" class="min-h-[60vh] flex flex-col justify-center mb-32">
    <div class="flex flex-col-reverse md:flex-row gap-12 items-center md:items-start justify-between fade-in">
        <div class="flex-1 space-y-6 text-center md:text-left">
            <h1 class="text-5xl sm:text-6xl font-light tracking-tight text-earth-800">
                Hi, I'm <span class="font-medium text-secondary">{data.firstName}</span>.
            </h1>
            <p class="text-xl sm:text-2xl text-earth-500 font-light">
                {data.role}
            </p>
            <p class="text-base text-earth-500 leading-relaxed max-w-lg mx-auto md:mx-0">
                {data.bio}
            </p>
            <div class="pt-4">
                <a href="#projects" class="inline-block border border-secondary text-secondary px-6 py-3 text-sm tracking-widest uppercase hover:bg-secondary hover:text-earth-50 transition-colors duration-300">
                    View Work
                </a>
            </div>
        </div>
        <div class="w-48 h-48 sm:w-64 sm:h-64 shrink-0 overflow-hidden border border-earth-200">
            <img src={data.profileImage} alt={data.firstName} class="w-full h-full object-cover transition-all duration-500">
        </div>
    </div>
</section>
