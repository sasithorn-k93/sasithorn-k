---
import { portfolioData } from '../data/portfolio.js';

const data = portfolioData.personal;
const socialLinks = portfolioData.social;
---

<section id="contact" class="border-t border-earth-200 pt-20">
    <h2 class="text-2xl font-light mb-6">Let's Connect</h2>
    <div id="contact-container" class="flex flex-col md:flex-row gap-10 justify-between items-start">
        <div class="space-y-4 text-lg font-light">
            <p class="text-earth-500 text-sm tracking-widest uppercase">Inquiries</p>
            <a href={`mailto:${data.email}`} class="block hover:text-earth-500 transition-colors">{data.email}</a>
            <p>{data.phone}</p>
            <p class="text-earth-500 text-sm mt-4">{data.location}</p>
        </div>
        <div class="space-y-4">
            <p class="text-earth-500 text-sm tracking-widest uppercase">Social</p>
            <div class="flex flex-col gap-3">
                {socialLinks.map((social) => (
                    <a href={social.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-earth-500 hover:text-earth-800 transition-colors group">
                        <Fragment set:html={social.icon} />
                        <span class="text-sm border-b border-transparent group-hover:border-earth-800">{social.name}</span>
                    </a>
                ))}
            </div>
        </div>
    </div>
</section>
